# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ─── CCP / EVE ESI ─────────────────────────────────────────────────────────────
CCP_CLIENT_ID=your_ccp_client_id_here
CCP_SECRET_KEY=your_ccp_secret_key_here

# The callback URL must point to your Railway public domain, e.g.:
# https://your-app-name.up.railway.app/callback/
CCP_REDIRECT_URI=https://your-app-name.up.railway.app/callback/

# ─── Database ──────────────────────────────────────────────────────────────────
# On Railway, add a PostgreSQL service to your project and Railway will
# automatically inject DATABASE_URL into your environment.
# The bot reads DB_HOST to decide whether to use PostgreSQL or SQLite.
# Copy the values from your Railway PostgreSQL service's "Connect" tab:
DB_HOST=your_railway_postgres_host
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your_railway_postgres_password
DB_PORT=5432

# ─── Optional ──────────────────────────────────────────────────────────────────
# Set the public-facing base URL (same as your Railway domain):
# BASE_URL=https://your-app-name.up.railway.app
